# ====== Base de donnees (PostgreSQL - Neon) ======
# Connexion poolee (runtime) : pooler Neon + pgbouncer=true (obligatoire avec Prisma).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Connexion directe (migrations / prisma db push) : meme hote SANS "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ====== Application ======
APP_URL="https://votre-domaine.vercel.app"
APP_NAME="OIJD"
APP_FULL_NAME="Organisation Internationale de la Jeunesse Diplomatique - Section CIV"
DIGITAL_ACCESS_NAME="Digital Access - Web Access Solution"

# ====== Securite ======
# Chaine aleatoire longue (ex: `openssl rand -base64 32`). A NE PAS partager.
AUTH_SECRET="change_me_with_a_long_random_string"
SEED_ADMIN_EMAIL="admin@oijd-civ.org"
SEED_ADMIN_PASSWORD="change_me"
SEED_ADMIN_NAME="Administrateur OIJD"

# ====== Emails ======
EMAIL_PROVIDER="log"            # log | smtp | resend
EMAIL_FROM="OIJD <noreply@oijd-civ.org>"
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ====== Stockage des fichiers ======
# En production sur Vercel : "vercel-blob" (connecter un store Blob au projet).
# BLOB_READ_WRITE_TOKEN est injecte automatiquement quand le store est connecte.
STORAGE_PROVIDER="vercel-blob"  # local | vercel-blob
STORAGE_LOCAL_DIR="storage/uploads"
BLOB_READ_WRITE_TOKEN=""
MAX_UPLOAD_MB="10"

# ====== Fonctionnalites ======
ENABLE_SMART_SCORING="true"
SMART_SCORING_THRESHOLD="30"
